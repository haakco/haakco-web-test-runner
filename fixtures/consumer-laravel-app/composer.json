{
  "name": "haakco/consumer-laravel-app-fixture",
  "description": "Minimal Laravel-style consumer fixture for haakco/test-sections-laravel portability checks.",
  "type": "project",
  "require": {
    "php": "^8.1",
    "haakco/test-sections-laravel": "@dev"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../packages/test-sections-laravel",
      "options": {
        "symlink": true
      }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test-sections:list": "php artisan test-sections:list",
    "test-sections:run": "php artisan test-sections:run --parallel=1"
  }
}
