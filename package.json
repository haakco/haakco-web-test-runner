{
  "name": "haakco-web-test-runner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "main": "./packages/test-sections-playwright/dist/index.js",
  "types": "./packages/test-sections-playwright/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/test-sections-playwright/dist/index.d.ts",
      "import": "./packages/test-sections-playwright/dist/index.js"
    }
  },
  "bin": {
    "haakco-test-sections": "./packages/test-sections-playwright/dist/cli.js"
  },
  "scripts": {
    "build": "cd packages/test-sections-playwright && pnpm exec tsc -p tsconfig.json --types node",
    "build:packages": "pnpm -r build",
    "test": "pnpm run test:packages",
    "test:packages": "pnpm -r --if-present test",
    "lint": "pnpm exec biome check . --colors=off && pnpm -r --if-present typecheck",
    "lint:biome": "pnpm exec biome check . --colors=off",
    "lint:fix": "pnpm exec biome check . --write --colors=off",
    "quality": "./ci/quality/run-quality-gates.sh",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
